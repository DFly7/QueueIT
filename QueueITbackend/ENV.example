# QueueIT Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# Application
ENVIRONMENT=development
APP_NAME=QueueIT API

# Logging Configuration
LOG_LEVEL=DEBUG
LOG_JSON=false

# Access Log Enrichment
LOG_REQUEST_BODY=true  # Set to true to log request bodies (POST/PUT/PATCH)
LOG_REQUEST_BODY_MAX_SIZE=1000  # Maximum body size to log (in bytes)

# Sentry (Optional - Error Tracking)
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Metrics (Prometheus)
ENABLE_METRICS=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLIC_ANON_KEY=your-anon-key-here
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Required for account deletion

# Spotify API
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Apple Music API
# ── Local dev: point to the .p8 file (never commit the file itself)
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-key-id
APPLE_MEDIA_ID=media.com.yourcompany.yourapp
APPLE_PRIVATE_KEY_PATH=certs/AuthKey_XXXXXXXX.p8

# ── Production (Railway / any cloud): base64-encode the .p8 and paste the string here.
#    Generate with: base64 -i AuthKey_XXXXXXXX.p8 | pbcopy
#    When this var is set it takes priority over APPLE_PRIVATE_KEY_PATH.
# APPLE_PRIVATE_KEY_BASE64=LS0tLS1CRUdJTi...

# Production overrides (when ENVIRONMENT=production):
# LOG_LEVEL=INFO
# LOG_JSON=true
# ALLOWED_ORIGINS=https://your-production-domain.com
